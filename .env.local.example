# ─── Database (server-side only — never sent to browser) ─────
# Required for Next.js API routes to access PostgreSQL via Prisma
# Must match the DATABASE_URL in the root .env
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/soroban_rentwatch

# ─── Backend API ──────────────────────────────────────────────
# URL of the running backend worker (future use for health checks etc.)
BACKEND_API_URL=http://localhost:3001

# ─── Public (exposed to browser) ─────────────────────────────
# Deposit account public key — shown on the Fund Balance page
# Must match DEPOSIT_ACCOUNT_PUBLIC in root .env
NEXT_PUBLIC_DEPOSIT_ACCOUNT=

# ─── Network ─────────────────────────────────────────────────
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_EXPLORER_URL=https://stellar.expert/explorer/testnet
